public static class Test
{
	static int Sum(List<int> list) //FAIL: swift
	{
		int sum = 0;
		foreach (int i in list)
			sum += i;
		return sum;
	}

	public static bool Run()
	{
		List<int>() list; //FAIL: cl
		list.Add(15);
		list.Add(5);
		list.Add(10);

		List<List<int>()>() lol;
		lol.Add();
		lol[0].Add(42);
		lol.Add();
		lol[1].Add(37);
		int s = 0;
		foreach (List<int> row in lol)
			s += row[0];
		return Sum(list) == 30 && s == 79;
	}
}
